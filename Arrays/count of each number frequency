public class manju{
public static void main(String[] args){
int a[]={1,2,1,2,1,2,1,5,5,5,5};
  boolean b[]=new boolean[a.length];
  for(int i=0;i<a.length;i++){
    if (b[i])continue;
    int c=0;
    for(int j=i+1;j<a.length;j++)
      {
        if(a[i]==a[j]){
          b[j]=true;
          c++;
      }
  System.out.println(a[i] + " -> " + c);
      }
    
}
}
