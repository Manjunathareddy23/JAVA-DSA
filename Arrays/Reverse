public class Main
{
	public static void main(String[] args) {
		int a[] = {21,23,1,2,3};
		
		int l = 0;
		int r = a.length - 1;
		int temp;

		while(l < r){
		    temp = a[l];
		    a[l] = a[r];
		    a[r] = temp;
		    
		    l++;
		    r--;
		}

		for(int k : a){
		    System.out.print(k + " ");
		}
	}
}
