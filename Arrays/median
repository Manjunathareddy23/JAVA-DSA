import java.util.Arrays;

public class MedianExample {
    public static void main(String[] args) {

        int[] arr = {3,1,4,2,5};
        Arrays.sort(arr);

        int n = arr.length;

        if(n % 2 == 1)
            System.out.println(arr[n/2]);
        else
            System.out.println((arr[n/2] + arr[n/2 - 1]) / 2.0);
    }
}
